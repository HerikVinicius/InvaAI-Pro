# ============================================================
# InvaAI Pro — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the actual .env file with real credentials to version control.

# ── Backend (Node.js/Express) ────────────────────────────────

# MongoDB connection string (MongoDB Atlas or local)
# Format: mongodb://user:pass@host:port/database
#         or mongodb+srv://user:pass@cluster.mongodb.net/database
MONGODB_URI=

# Secret key for JWT token signing (use: openssl rand -hex 64)
# Must be a long, random string unique to your environment
JWT_SECRET=

# Express server port (default: 5000)
PORT=5000

# Node environment (development | production)
NODE_ENV=development

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# ── Frontend (React/Vite) ────────────────────────────────────

# Backend API URL (where Express server is running)
VITE_API_URL=http://localhost:5000/api
