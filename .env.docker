# ============================================================
# Docker Environment Configuration
# ============================================================
# Copie este arquivo para .env antes de usar docker-compose
# cp .env.docker .env

# MongoDB Configuration
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DATABASE=invaai_prod

# Node Environment
NODE_ENV=production
PORT=5000

# JWT Secret (MUDE ISSO EM PRODUÇÃO!)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-in-production

# Anthropic API Key (opcional)
ANTHROPIC_API_KEY=

# Database URI (MongoDB)
# Formato: mongodb://user:password@host:port/database?authSource=admin
MONGODB_URI=mongodb://admin:admin@mongodb:27017/invaai_prod?authSource=admin

# Frontend API URL (do ponto de vista do container)
VITE_API_BASE_URL=http://localhost:5000
